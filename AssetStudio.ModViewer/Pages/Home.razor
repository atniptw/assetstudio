@page "/"
@inject IJSRuntime JS
@inject DiagnosticsService Diagnostics
@inject BasePackageLoader Loader
@inject ModImportService ModImport
@inject ModStorageService ModStorage
@inject AssetExtractor Extractor
@implements IDisposable
@using System.IO
@using System.Text.Json
@using System.Text.Json.Serialization
@using AssetStudio.ModViewer.Models
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>ModViewer</PageTitle>

<div class="viewer-page">
	<header class="page-header">
		<div>
			<h1>ModViewer</h1>
			<p class="subtle">Base avatar + mod dress-up</p>
		</div>
		<span class="subtle">Status: @Loader.PackageStatus</span>
	</header>

	<div class="viewer-layout">
		<section class="left-panel">

			<button class="btn btn-outline-light import-btn" @onclick="OpenImportPickerAsync">Import Mod</button>
			<InputFile id="mod-zip-input" class="hidden-file-input" accept=".zip,application/zip" OnChange="HandleModZipSelectedAsync" />

			@if (!string.IsNullOrWhiteSpace(ImportBannerMessage))
			{
				<div class="import-banner @ImportBannerLevel">@ImportBannerMessage</div>
			}

			<div class="tab-row">
				@foreach (var tab in Tabs)
				{
					<button class="tab-btn @(SelectedTab == tab ? "active" : string.Empty)" @onclick="() => SelectTab(tab)">@tab</button>
				}
			</div>

			<div class="asset-list" role="list" aria-label="Toggleable assets">
				@if (FilteredItems.Count == 0)
				{
					<div class="asset-empty">Upload a mod zip to populate this list.</div>
				}
				else
				{
					@foreach (var item in FilteredItems)
					{
						<label class="asset-row">
							<input type="checkbox" checked="@item.Enabled" @onchange="(e) => OnToggleItemChanged(item, e.Value)" />
							<span>@item.DisplayName</span>
							<span class="asset-tag">@item.BodyPartTag</span>
						</label>
					}
				}
			</div>
		</section>

		<section class="viewer-panel right-panel">
			<canvas id="viewer-canvas" class="viewer-canvas"></canvas>

			<div class="viewer-controls">
				<button class="btn btn-outline-light btn-sm" @onclick="OpenDiagnostics">Diagnostics</button>
				<button class="btn btn-outline-light btn-sm" @onclick="ClearIndexedDbAsync">Clear IndexedDB</button>
			</div>
		</section>
	</div>
</div>

@if (DiagnosticsModalOpen)
{
	<div class="diag-modal-backdrop" @onclick="CloseDiagnostics">
		<div class="diag-modal" @onclick:stopPropagation="true">
			<header class="diag-modal-header">
				<div>
					<h3>Diagnostics</h3>
					<p class="subtle">Visible only when needed</p>
				</div>
				<div class="diag-modal-actions">
					<button class="btn btn-sm btn-outline-light" @onclick="ReloadAsync">Reload</button>
					<button class="btn btn-sm btn-outline-light" @onclick="CloseDiagnostics">Close</button>
				</div>
			</header>

			<div class="diag-summary">
				<div>
					<span class="label">Package</span>
					<span class="value">@Loader.PackageStatus</span>
				</div>
				<div>
					<span class="label">Bytes</span>
					<span class="value">@Loader.PackageBytesLength</span>
				</div>
				<div>
					<span class="label">Elapsed</span>
					<span class="value">@Loader.LastElapsedMs ms</span>
				</div>
			</div>

			<div class="diag-log">
				@if (Diagnostics.Entries.Count == 0)
				{
					<div class="log-row">
						<span class="time">--:--:--</span>
						<span class="level">info</span>
						<span class="message">Waiting for package load...</span>
					</div>
				}
				else
				{
					@foreach (var entry in Diagnostics.Entries)
					{
						<div class="log-row log-@entry.Level">
							<span class="time">@entry.Timestamp.ToString("HH:mm:ss")</span>
							<span class="level">@entry.Level</span>
							<span class="message">@entry.Message</span>
						</div>
					}
				}
			</div>
		</div>
	</div>
}

@code {
	private bool initialized;
	private bool DiagnosticsModalOpen;
	private string SelectedTab = "All";
	private string ImportBannerMessage = string.Empty;
	private string ImportBannerLevel = "info";

	private static readonly List<string> Tabs = new() { "All", "Head", "Neck", "Body", "Hip", "LeftArm", "RightArm", "LeftLeg", "RightLeg", "World" };

	private List<PersistedModFile> StoredItems = new();

	private List<PersistedModFile> FilteredItems =>
		SelectedTab == "All"
			? StoredItems
			: StoredItems.Where(item => string.Equals(item.BodyPartTag, SelectedTab, StringComparison.OrdinalIgnoreCase)).ToList();

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender || initialized)
		{
			return;
		}

		initialized = true;
		Diagnostics.OnChanged += HandleDiagnosticsChanged;
		await JS.InvokeVoidAsync("modViewer.init", "viewer-canvas");
		
		// Set JS runtime for asset rendering
		Loader.SetJSRuntime(JS);
		await Loader.LoadAsync();
		await LoadStoredFilesAsync();
	}

	private async Task ReloadAsync()
	{
		Diagnostics.Clear();
		await JS.InvokeVoidAsync("modViewer.clearModAssets");
		await Loader.LoadAsync();
	}

	private void OpenDiagnostics()
	{
		DiagnosticsModalOpen = true;
	}

	private void CloseDiagnostics()
	{
		DiagnosticsModalOpen = false;
	}

	private void SelectTab(string tab)
	{
		SelectedTab = tab;
	}

	private async Task OpenImportPickerAsync()
	{
		await JS.InvokeVoidAsync("modViewer.openFilePicker", "mod-zip-input");
	}

	private async Task HandleModZipSelectedAsync(InputFileChangeEventArgs args)
	{
		var zipFile = args.File;
		if (zipFile is null)
		{
			return;
		}

		if (!string.Equals(Path.GetExtension(zipFile.Name), ".zip", StringComparison.OrdinalIgnoreCase))
		{
			Diagnostics.Add("warn", $"Unsupported file type: {zipFile.Name}. Import expects a .zip file.");
			return;
		}

		try
		{
			var importSummary = await ModImport.ImportZipAsync(zipFile);
			var validItems = importSummary.Items.Where(item => item.IsValid).ToList();
			if (validItems.Count > 0)
			{
				await ModStorage.StoreValidFilesAsync(validItems);
			}

			await LoadStoredFilesAsync();

			ImportBannerLevel = importSummary.RejectedCount > 0 ? "warn" : "info";
			ImportBannerMessage = $"{zipFile.Name}: {validItems.Count} stored, {importSummary.RejectedCount} rejected.";

			if (importSummary.TotalHhhFiles == 0)
			{
				Diagnostics.Add("warn", $"{zipFile.Name}: no .hhh files found.");
			}
			else
			{
				Diagnostics.Add("info", $"{zipFile.Name}: {validItems.Count} stored, {importSummary.RejectedCount} rejected.");
				foreach (var invalid in importSummary.Items.Where(item => !item.IsValid))
				{
					Diagnostics.Add("warn", $"Rejected {invalid.FileName}: {invalid.ErrorMessage}");
				}
			}
		}
		catch (Exception ex)
		{
			ImportBannerLevel = "error";
			ImportBannerMessage = "Import failed.";
			Diagnostics.Add("error", $"Mod import failed: {ex.Message}");
		}
	}

	private async Task ClearIndexedDbAsync()
	{
		try
		{
			await ModStorage.ClearAsync();
			await JS.InvokeVoidAsync("modViewer.clearModAssets");
			StoredItems.Clear();
			ImportBannerLevel = "info";
			ImportBannerMessage = "Stored mods cleared.";
			Diagnostics.Add("info", "Mod storage cleared from IndexedDB.");
		}
		catch (Exception ex)
		{
			Diagnostics.Add("warn", $"Unable to clear IndexedDB: {ex.Message}");
		}
	}

	private async Task LoadStoredFilesAsync()
	{
		StoredItems = await ModStorage.GetValidFilesAsync();
		StateHasChanged();
	}

	private async Task OnToggleItemChanged(PersistedModFile item, object? value)
	{
		item.Enabled = value is bool b && b;

		if (!item.Enabled)
		{
			await JS.InvokeVoidAsync("modViewer.removeModAsset", item.Id);
			Diagnostics.Add("info", $"Removed mod: {item.DisplayName}");
			return;
		}

		if (string.IsNullOrWhiteSpace(item.DataBase64))
		{
			item.Enabled = false;
			Diagnostics.Add("warn", $"Missing .hhh payload for {item.DisplayName}");
			return;
		}

		try
		{
			var bytes = Convert.FromBase64String(item.DataBase64);
			var avatarData = await Extractor.ExtractStaticAssetAsync(bytes, item.FileName);
			Diagnostics.Add("info", $"Extracted {item.DisplayName}: meshes={avatarData.Meshes.Count}, materials={avatarData.Materials.Count}, textures={avatarData.Textures.Count}, anchors={avatarData.AttachmentAnchors.Count}");

			if (avatarData.Meshes.Count == 0)
			{
				item.Enabled = false;
				Diagnostics.Add("warn", $"No meshes extracted for {item.DisplayName}; skipping render.");
				return;
			}

			var options = new JsonSerializerOptions
			{
				PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
				DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
			};

			var json = JsonSerializer.Serialize(avatarData, options);
			var addResult = await JS.InvokeAsync<ModRenderResult>("modViewer.addModAsset", item.Id, json, item.BodyPartTag?.ToLowerInvariant());
			var renderState = await JS.InvokeAsync<ModRenderState>("modViewer.getRenderState");
			Diagnostics.Add("info", $"Render add result for {item.DisplayName}: added={addResult?.Added}, reason={addResult?.Reason}, anchor={addResult?.AnchorTag}, anchorFound={addResult?.AnchorFound}, modGroups={addResult?.ModGroupCount}, sceneMeshes={renderState?.SceneMeshCount}, modMeshes={addResult?.MeshCount}, boundsCenter=[{FormatVector(addResult?.BoundsCenter)}], boundsSize=[{FormatVector(addResult?.BoundsSize)}]");
			Diagnostics.Add("info", $"Rendered mod: {item.DisplayName} ({item.BodyPartTag})");
		}
		catch (Exception ex)
		{
			item.Enabled = false;
			Diagnostics.Add("warn", $"Unable to render mod {item.DisplayName}: {ex.Message}");
		}
	}

	private sealed class ModRenderResult
	{
		public bool Added { get; set; }
		public string? Reason { get; set; }
		public string? AnchorTag { get; set; }
		public bool AnchorFound { get; set; }
		public int ModGroupCount { get; set; }
		public int MeshCount { get; set; }
		public float[]? BoundsCenter { get; set; }
		public float[]? BoundsSize { get; set; }
	}

	private sealed class ModRenderState
	{
		public int SceneMeshCount { get; set; }
		public int ModGroupCount { get; set; }
		public int AnchorCount { get; set; }
		public int AvatarMeshCount { get; set; }
	}

	private static string FormatVector(float[]? value)
	{
		if (value is null || value.Length == 0)
		{
			return "n/a";
		}

		return string.Join(", ", value.Select(component => component.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)));
	}

	private void HandleDiagnosticsChanged()
	{
		InvokeAsync(StateHasChanged);
	}

	public void Dispose()
	{
		Diagnostics.OnChanged -= HandleDiagnosticsChanged;
	}
}
