@page "/"
@inject IJSRuntime JS
@inject DiagnosticsService Diagnostics
@inject BasePackageLoader Loader
@implements IDisposable

<PageTitle>ModViewer</PageTitle>

<div class="viewer-page">
	<header class="page-header">
		<div>
			<h1>ModViewer</h1>
			<p class="subtle">Base avatar + mod dress-up</p>
		</div>
		<span class="subtle">Status: @Loader.PackageStatus</span>
	</header>

	<div class="viewer-layout">
		<section class="left-panel">

			<button class="btn btn-outline-light import-btn" @onclick="ImportModPlaceholderAsync">Import Mod</button>

			<div class="tab-row">
				@foreach (var tab in Tabs)
				{
					<button class="tab-btn @(SelectedTab == tab ? "active" : string.Empty)" @onclick="() => SelectTab(tab)">@tab</button>
				}
			</div>

			<div class="asset-list" role="list" aria-label="Toggleable assets">
				@if (FilteredItems.Count == 0)
				{
					<div class="asset-empty">No assets in this tab.</div>
				}
				else
				{
					@foreach (var item in FilteredItems)
					{
						<label class="asset-row">
							<input type="checkbox" checked="@item.Enabled" @onchange="(e) => OnToggleItemChanged(item, e.Value)" />
							<span>@item.Name</span>
						</label>
					}
				}
			</div>
		</section>

		<section class="viewer-panel right-panel">
			<canvas id="viewer-canvas" class="viewer-canvas"></canvas>

			<div class="viewer-controls">
				<button class="btn btn-outline-light btn-sm" @onclick="OpenDiagnostics">Diagnostics</button>
				<button class="btn btn-outline-light btn-sm" @onclick="ClearIndexedDbAsync">Clear IndexedDB</button>
			</div>
		</section>
	</div>
</div>

@if (DiagnosticsModalOpen)
{
	<div class="diag-modal-backdrop" @onclick="CloseDiagnostics">
		<div class="diag-modal" @onclick:stopPropagation="true">
			<header class="diag-modal-header">
				<div>
					<h3>Diagnostics</h3>
					<p class="subtle">Visible only when needed</p>
				</div>
				<div class="diag-modal-actions">
					<button class="btn btn-sm btn-outline-light" @onclick="ReloadAsync">Reload</button>
					<button class="btn btn-sm btn-outline-light" @onclick="CloseDiagnostics">Close</button>
				</div>
			</header>

			<div class="diag-summary">
				<div>
					<span class="label">Package</span>
					<span class="value">@Loader.PackageStatus</span>
				</div>
				<div>
					<span class="label">Bytes</span>
					<span class="value">@Loader.PackageBytesLength</span>
				</div>
				<div>
					<span class="label">Elapsed</span>
					<span class="value">@Loader.LastElapsedMs ms</span>
				</div>
			</div>

			<div class="diag-log">
				@if (Diagnostics.Entries.Count == 0)
				{
					<div class="log-row">
						<span class="time">--:--:--</span>
						<span class="level">info</span>
						<span class="message">Waiting for package load...</span>
					</div>
				}
				else
				{
					@foreach (var entry in Diagnostics.Entries)
					{
						<div class="log-row log-@entry.Level">
							<span class="time">@entry.Timestamp.ToString("HH:mm:ss")</span>
							<span class="level">@entry.Level</span>
							<span class="message">@entry.Message</span>
						</div>
					}
				}
			</div>
		</div>
	</div>
}

@code {
	private bool initialized;
	private bool DiagnosticsModalOpen;
	private string SelectedTab = "All";

	private static readonly List<string> Tabs = new()
	{
		"All",
		"Head",
		"Body",
		"Limb",
		"World"
	};

	private readonly List<ToggleItem> ToggleItems = new()
	{
		new ToggleItem("Hat_A", "Head", true),
		new ToggleItem("Mask_A", "Head", false),
		new ToggleItem("Top_A", "Body", true),
		new ToggleItem("Pants_A", "Body", true),
		new ToggleItem("ArmBand_A", "Limb", false),
		new ToggleItem("World_Effect_A", "World", false)
	};

	private List<ToggleItem> FilteredItems =>
		SelectedTab == "All"
			? ToggleItems
			: ToggleItems.Where(item => item.Tab == SelectedTab).ToList();

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender || initialized)
		{
			return;
		}

		initialized = true;
		Diagnostics.OnChanged += HandleDiagnosticsChanged;
		await JS.InvokeVoidAsync("modViewer.init", "viewer-canvas");
		
		// Set JS runtime for asset rendering
		Loader.SetJSRuntime(JS);
		await Loader.LoadAsync();
	}

	private async Task ReloadAsync()
	{
		Diagnostics.Clear();
		await Loader.LoadAsync();
	}

	private void OpenDiagnostics()
	{
		DiagnosticsModalOpen = true;
	}

	private void CloseDiagnostics()
	{
		DiagnosticsModalOpen = false;
	}

	private void SelectTab(string tab)
	{
		SelectedTab = tab;
	}

	private async Task ImportModPlaceholderAsync()
	{
		Diagnostics.Add("info", "Import Mod placeholder clicked");
		await Task.CompletedTask;
	}

	private async Task ClearIndexedDbAsync()
	{
		try
		{
			await JS.InvokeVoidAsync("modViewer.clearIndexedDb");
			Diagnostics.Add("info", "IndexedDB clear request completed");
		}
		catch (Exception ex)
		{
			Diagnostics.Add("warn", $"Unable to clear IndexedDB: {ex.Message}");
		}
	}

	private void OnToggleItemChanged(ToggleItem item, object? value)
	{
		item.Enabled = value is bool b && b;
	}

	private void HandleDiagnosticsChanged()
	{
		InvokeAsync(StateHasChanged);
	}

	public void Dispose()
	{
		Diagnostics.OnChanged -= HandleDiagnosticsChanged;
	}

	private sealed class ToggleItem
	{
		public ToggleItem(string name, string tab, bool enabled)
		{
			Name = name;
			Tab = tab;
			Enabled = enabled;
		}

		public string Name { get; }
		public string Tab { get; }
		public bool Enabled { get; set; }
	}
}
